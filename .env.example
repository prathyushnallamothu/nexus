# Nexus model selection. Use provider:model.
NEXUS_MODEL=anthropic:claude-sonnet-4-20250514

# Per-session budget in USD.
NEXUS_BUDGET=2.0

# Runtime data directory. Defaults to .nexus in the current workspace.
NEXUS_HOME=.nexus

# Sandbox mode. Supported values today: local, docker.
NEXUS_SANDBOX=local

# Set the key for the provider selected by NEXUS_MODEL.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Optional search providers for the web_search tool.
EXA_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=

# Optional runtime backing services.
DATABASE_URL=
REDIS_URL=
