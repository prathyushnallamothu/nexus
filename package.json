{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "description": "The AI agent that gets smarter and cheaper over time",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run apps/cli/src/index.ts",
    "build": "bun run --filter '*' build",
    "lint": "tsc --noEmit",
    "clean": "rimraf packages/*/dist apps/*/dist"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
